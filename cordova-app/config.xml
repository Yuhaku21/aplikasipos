<?xml version='1.0' encoding='utf-8'?>
<widget id="com.tranzivo.pos" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
  <name>Tranzivo POS</name>
  <description>Tranzivo point-of-sale app packaged with Cordova.</description>
  <author email="support@tranzivo.id" href="https://tranzivo.id">Tranzivo</author>
  <content src="index.html" />
  <access origin="*" />
  <allow-navigation href="*" />
  <allow-intent href="http://*/*" />
  <allow-intent href="https://*/*" />
  <platform name="android">
    <allow-intent href="market:*" />
  </platform>
  <preference name="DisallowOverscroll" value="true" />
  <preference name="Fullscreen" value="false" />
  <preference name="WebViewBounce" value="false" />
  <platform name="ios">
    <allow-intent href="itms:*" />
    <allow-intent href="itms-apps:*" />
  </platform>
</widget>
